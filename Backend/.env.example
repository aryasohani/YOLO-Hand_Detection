# ── Model ─────────────────────────────────────────
MODEL_PATH=best.pt
CONF_THRESHOLD=0.25
TRAIL_LENGTH=30

# ── Storage ───────────────────────────────────────
UPLOAD_DIR=app/uploads
OUTPUT_DIR=app/outputs
MAX_FILE_SIZE_MB=500

# ── CORS (comma-separated list in quotes) ─────────
# ALLOWED_ORIGINS=["http://localhost:5173","https://yourdomain.com"]

# ── App ───────────────────────────────────────────
APP_TITLE=HandTrack AI
APP_VERSION=1.0.0
DEBUG=false
